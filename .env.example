# Copy to .env and fill in. .env is gitignored -- never commit it.

# --- Azure OpenAI (required) ---
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<key>
AZURE_OPENAI_API_VERSION=2024-10-21

# Embedding deployment (3072-dim text-embedding-3-large).
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMS=3072

# Chat deployment for grounded synthesis. FAST is preferred (cheaper);
# DEPLOYMENT is the fallback when FAST is unset.
AZURE_OPENAI_DEPLOYMENT_FAST=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- YouTube domain (optional) ---
# Answer LLM: "azure" (reuse the Azure chat deployment above) or "claude".
# If unset: claude when ANTHROPIC_API_KEY is present, else azure.
# RAG_YOUTUBE_CHAT_PROVIDER=azure
# ANTHROPIC_API_KEY=<key>            # only if using claude

# Pace transcript fetches (seconds between videos) to avoid YouTube per-IP
# rate-limiting on large channels. Default 1.0; raise to 3-5 for big pulls.
# RAG_YT_SLEEP=3

# Proxy for bulk transcript pulls (YouTube rate-limits per IP). Pick ONE:
#   Webshare residential (recommended -- auto-rotates + retries on block):
# RAG_YT_WEBSHARE_USERNAME=<user>
# RAG_YT_WEBSHARE_PASSWORD=<pass>
#   or a generic proxy (creds embedded in the URL):
# RAG_YT_PROXY=http://user:pass@host:port
# RAG_YT_PROXY_HTTPS=https://user:pass@host:port

# --- Optional paths (defaults are <repo>/corpora and <repo>/.index) ---
# DOCRAG_DOCS_ROOT=C:\path\to\corpora
# DOCRAG_INDEX_DIR=C:\path\to\index
