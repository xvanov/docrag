# Copy to .env and fill in. .env is gitignored -- never commit it.

# --- Azure OpenAI (required) ---
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<key>
AZURE_OPENAI_API_VERSION=2024-10-21

# Embedding deployment (3072-dim text-embedding-3-large).
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMS=3072

# Chat deployment for grounded synthesis. FAST is preferred (cheaper);
# DEPLOYMENT is the fallback when FAST is unset.
AZURE_OPENAI_DEPLOYMENT_FAST=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Optional paths (defaults are <repo>/corpora and <repo>/.index) ---
# DOCRAG_DOCS_ROOT=C:\path\to\corpora
# DOCRAG_INDEX_DIR=C:\path\to\index
